{
  "name": "team-task-manager",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
